AI_BASE_URL=http://localhost:9009/v1
AI_API_KEY=your-ai-api-key-here
AI_MODEL=gemini-3.0-pro

# Writer / Auditor → Ollama local model (avoid Web2API instability)
AI_WRITER_BASE_URL=http://localhost:11434/v1
AI_WRITER_API_KEY=ollama
AI_WRITER_MODEL=qwen2.5:14b-instruct

# Official API keys (fallback when gateway is down)
GEMINI_API_KEY=your-gemini-api-key-here
GROK_OFFICIAL_API_KEY=your-grok-api-key-here
SERPAPI_API_KEY=your-serpapi-api-key-here

# GitHub
GITHUB_TOKEN=your-github-token

# Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=hermit-purple/1.0

# Database (optional override, defaults to data/hermit.db)
# DATABASE_URL=sqlite:///data/hermit.db

# Perplexica (self-hosted AI search)
PERPLEXICA_API_URL=http://localhost:3100
